{
  "$schema": "https://turborepo.com/schema.json",
  "concurrency": "32",
  "globalPassThroughEnv": [
    "BIRD_API_KEY",
    "BIRD_SMS_CHANNEL_ID",
    "BIRD_WORKSPACE_ID",
    "EDGE_CONFIG",
    "ENABLE_EXPERIMENTAL_COREPACK",
    "GRIDA_S2S_PRIVATE_API_KEY",
    "INTEGRATIONS_TEST_TOSSPAYMENTS_CUSTOMER_KEY",
    "INTEGRATIONS_TEST_TOSSPAYMENTS_SECRET_KEY",
    "IPINFO_ACCESS_TOKEN",
    "OPENAI_API_KEY",
    "REDIS_URL",
    "REPLICATE_API_TOKEN",
    "RESEND_API_KEY",
    "SENTRY_AUTH_TOKEN",
    "SENTRY_HOST",
    "SENTRY_ORG",
    "SENTRY_PROJECT",
    "SENTRY_PROJECT_ID",
    "STRIPE_SECRET_KEY",
    "SUPABASE_PUBLISHABLE_KEY",
    "SUPABASE_SECRET_KEY",
    "UNSPLASH_API_KEY",
    "UPSTASH_REDIS_REST_TOKEN",
    "UPSTASH_REDIS_REST_URL"
  ],
  "tasks": {
    "generate": {
      "outputs": []
    },
    "test": {
      "dependsOn": ["^build"]
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "build/**", "dist/**"]
    },
    "typecheck": {
      "dependsOn": ["^typecheck"]
    },
    "dev": {
      "persistent": true,
      "cache": false
    }
  }
}
