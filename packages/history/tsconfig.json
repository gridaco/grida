{
  "compilerOptions": {
    "target": "es2020",
    "module": "esnext",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "strict": true,
    "noImplicitAny": true,
    "skipLibCheck": true,
    "declaration": true,
    "outDir": "dist",
    "types": ["vitest/globals", "node"]
  },
  "include": ["src"],
  "exclude": ["dist", "__tests__"]
}
