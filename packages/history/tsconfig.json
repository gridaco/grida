{
  "compilerOptions": {
    "target": "es2020",
    "module": "esnext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "strict": true,
    "noImplicitAny": true,
    "skipLibCheck": true,
    "declaration": true,
    "types": [
      "vitest/globals",
      "node"
    ]
  },
  "include": [
    "src",
    "__tests__"
  ],
  "exclude": [
    "dist"
  ]
}