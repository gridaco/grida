{
  "name": "@grida/history",
  "version": "0.0.0",
  "description": "dependency-free transaction and undo/redo engine",
  "license": "MIT",
  "author": "softmarshmallow",
  "repository": "https://github.com/gridaco/grida",
  "files": [
    "dist"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsdown --platform neutral src/index.ts --format cjs --format esm --dts",
    "dev": "tsdown --platform neutral src/index.ts --format cjs --format esm --dts --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "tsdown": "^0.21.9",
    "typescript": "^5.0.0",
    "vitest": "^4"
  }
}
