{
  "name": "@grida/daemon",
  "version": "0.0.0",
  "private": true,
  "description": "Grida local daemon: the GRIDA-SEC-004 request perimeter and default loopback HTTP adapter that host capability tenants (files, recents, workspaces, secrets store) — the Grida AI agent is one tenant, not the owner. AI-free by contract.",
  "license": "MIT",
  "author": "Grida",
  "repository": "https://github.com/gridaco/grida",
  "files": [
    "dist",
    "src"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./server": {
      "import": {
        "types": "./dist/server.d.mts",
        "default": "./dist/server.mjs"
      },
      "require": {
        "types": "./dist/server.d.cts",
        "default": "./dist/server.cjs"
      }
    },
    "./sandbox": {
      "import": {
        "types": "./dist/sandbox/index.d.mts",
        "default": "./dist/sandbox/index.mjs"
      },
      "require": {
        "types": "./dist/sandbox/index.d.cts",
        "default": "./dist/sandbox/index.cjs"
      }
    },
    "./transport": {
      "import": {
        "types": "./dist/transport.d.mts",
        "default": "./dist/transport.mjs"
      },
      "require": {
        "types": "./dist/transport.d.cts",
        "default": "./dist/transport.cjs"
      }
    }
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "prepack": "tsdown",
    "test": "vitest run",
    "test:browser": "vitest run --config vitest.browser.config.ts",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.neutral.json"
  },
  "dependencies": {
    "@hono/node-server": "1.19.9",
    "hono": "4.11.8"
  },
  "devDependencies": {
    "@vitest/browser-playwright": "4.0.18",
    "playwright": "^1.58.2",
    "tsdown": "^0.22.1",
    "typescript": "^6",
    "vitest": "^4"
  }
}
