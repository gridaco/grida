// https://oxc.rs/docs/guide/usage/formatter/config-file-reference.html
{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "printWidth": 80,
  "trailingComma": "es5",
  "experimentalSortPackageJson": {
    "sortScripts": true,
  },
  "ignorePatterns": [
    "third_party/externals",
    ".legacy",
    ".json5",
    "bin",
    "*.clipboard.html",
  ],
}
