    <text x="52" y="6" width="190" font-size="13" font-weight="700" fill="#0F0F0F">{account}</text>
    <text x="52" y="26" width="210" font-size="11" fill="#737373">{detail}</text>
    <text x="end 0" y="12" width="50" font-size="11" font-weight="700" fill="#0095F6">Follow</text>
  </component>

