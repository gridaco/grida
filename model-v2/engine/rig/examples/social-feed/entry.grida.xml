<grida version="3">
  <!-- Demo-only fictional identities and content; both photo assets were generated for this fixture. -->
  <component id="story-item" width="92" height="108">
    <prop name="label" type="string"/>
    <prop name="initial" type="string"/>
    <prop name="avatar-color" type="color"/>

    <ellipse x="2" width="88" height="88">
      <fill>
        <gradient kind="linear" from="0 1" to="1 0">
          <stop offset="0" color="#F59E0B"/>
          <stop offset="0.5" color="#EC4899"/>
          <stop offset="1" color="#7C3AED"/>
        </gradient>
      </fill>
      <ellipse x="3" y="3" width="82" height="82" fill="#FFFFFF">
        <ellipse x="3" y="3" width="76" height="76" fill="{avatar-color}">
          <text x="center" y="center" font-size="14" font-weight="700" fill="#FFFFFF">{initial}</text>
        </ellipse>
      </ellipse>
    </ellipse>
    <text x="center" y="94" font-size="10" fill="#262626">{label}</text>
  </component>

  <component id="suggestion-row" width="320" height="52">
    <prop name="account" type="string"/>
    <prop name="detail" type="string"/>
    <prop name="initial" type="string"/>
    <prop name="avatar-color" type="color"/>

    <ellipse y="6" width="40" height="40" fill="{avatar-color}">
