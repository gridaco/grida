{
  "name": "desktop",
  "version": "0.0.2",
  "private": true,
  "description": "Grida Desktop App",
  "keywords": [],
  "homepage": "https://grida.co",
  "license": "MIT",
  "author": {
    "name": "Grida",
    "email": "hello@grida.co"
  },
  "repository": "https://github.com/gridaco/grida",
  "main": ".vite/build/main.js",
  "scripts": {
    "dev": "node scripts/prepare-dev-electron-branding.mjs && electron-forge start",
    "dev:insiders": "node scripts/prepare-dev-electron-branding.mjs --insiders && electron-forge start -- --insiders",
    "make": "node scripts/prepare-dev-electron-branding.mjs && electron-forge make",
    "package": "node scripts/prepare-dev-electron-branding.mjs && electron-forge package",
    "publish:prerelease": "node scripts/prepare-dev-electron-branding.mjs && electron-forge publish",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@ai-sdk/gateway": "3.0.66",
    "@ai-sdk/openai-compatible": "2.0.47",
    "@anthropic-ai/sandbox-runtime": "^0.0.52",
    "@grida/agent": "link:../packages/grida-ai-agent",
    "@grida/ai-models": "link:../packages/grida-ai-models",
    "@grida/desktop-bridge": "link:../packages/grida-desktop-bridge",
    "@grida/home": "link:../packages/grida-home",
    "@hono/node-server": "^1.13.7",
    "ai": "6.0.116",
    "clsx": "^2.1.1",
    "electron-squirrel-startup": "^1.0.1",
    "hono": "^4.6.14",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "tailwind-merge": "^3.5.0",
    "undici": "^7.24.4",
    "update-electron-app": "^3.2.0"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.11.1",
    "@electron-forge/maker-deb": "^7.11.1",
    "@electron-forge/maker-dmg": "^7.11.1",
    "@electron-forge/maker-rpm": "^7.11.1",
    "@electron-forge/maker-squirrel": "^7.11.1",
    "@electron-forge/maker-zip": "^7.11.1",
    "@electron-forge/plugin-auto-unpack-natives": "^7.11.1",
    "@electron-forge/plugin-fuses": "^7.11.1",
    "@electron-forge/plugin-vite": "^7.11.1",
    "@electron-forge/publisher-github": "^7.11.1",
    "@electron-forge/shared-types": "^7.11.1",
    "@electron/fuses": "^1.8.0",
    "@tailwindcss/vite": "^4.2.2",
    "@types/electron-squirrel-startup": "^1.0.2",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.2",
    "dotenv": "^17.4.2",
    "electron": "^42.2.0",
    "tailwindcss": "^4.2.2",
    "ts-node": "^10.0.0",
    "typescript": "^6",
    "vite": "^8.0.13",
    "vitest": "^4"
  },
  "packageManager": "pnpm@10.24.0",
  "pnpm": {
    "overrides": {
      "@grida/agent": "link:../packages/grida-ai-agent",
      "@grida/desktop-bridge": "link:../packages/grida-desktop-bridge",
      "@grida/ai-models": "link:../packages/grida-ai-models",
      "@grida/home": "link:../packages/grida-home"
    }
  }
}
