APPLE_ID='<your-apple-id>'
APPLE_PASSWORD='<your-apple-app-specific-password>'
APPLE_TEAM_ID='<your-apple-team-id>'
GITHUB_TOKEN='<your-github-token>'

# --- gridad / Supabase ---
#
# These are baked into the daemon at build time (vite.daemon.config.ts).
# Match the names used by editor/.env.local so a single .env works for
# both surfaces. The daemon refuses to start with empty values.
NEXT_PUBLIC_SUPABASE_URL='https://<project-ref>.supabase.co'
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY='sb_publishable_...'